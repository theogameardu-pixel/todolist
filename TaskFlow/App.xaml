<Application x:Class="TaskFlow.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TaskFlow.Converters">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StatusToTextDecorationConverter x:Key="StatusToTextDecorationConverter"/>
        <converters:ProgressToPercentageConverter x:Key="ProgressToPercentageConverter"/>

        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF6F6F7"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="White"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF4F46E5"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FF18181B"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#FF71717A"/>
    </Application.Resources>
</Application>
