<Window x:Class="TaskFlow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TaskFlow.Models"
        xmlns:vm="clr-namespace:TaskFlow.ViewModels"
        mc:Ignorable="d"
        Title="TaskFlow"
        Height="720"
        Width="1200"
        Background="{DynamicResource BackgroundBrush}"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TaskFlow" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <Button Content="+ Nouveau projet" Command="{Binding AddProjectCommand}" Margin="0,12,0,8"/>
                </StackPanel>

                <ListBox ItemsSource="{Binding Projects}"
                         SelectedItem="{Binding SelectedProject}"
                         DisplayMemberPath="Name"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource TextBrush}"/>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBox Width="240" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="150" SelectedItem="{Binding SelectedFilter}" ItemsSource="{Binding FilterValues}" VerticalAlignment="Center"/>
                <Button Content="Thème" Command="{Binding ToggleThemeCommand}" Margin="10,0,0,0"/>
            </DockPanel>

            <DockPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" Width="280" Margin="0,0,10,0"/>
                <Button Content="Ajouter une tâche" Command="{Binding AddTaskCommand}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Progression: " Foreground="{DynamicResource MutedBrush}" Margin="20,0,4,0"/>
                    <TextBlock Text="{Binding CompletionRate, Converter={StaticResource ProgressToPercentageConverter}}" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" Padding="12">
                <ListBox x:Name="TasksList"
                         ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding SelectedTask}"
                         AllowDrop="True"
                         PreviewMouseMove="TasksList_PreviewMouseMove"
                         Drop="TasksList_Drop"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TaskItem}">
                            <Border Margin="0,0,0,8" Padding="10" BorderBrush="#22000000" BorderThickness="1">
                                <DockPanel>
                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=OneWay}" Command="{Binding DataContext.ToggleTaskStatusCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,10,0"/>
 codex/generate-windows-to-do-list-application-8ppoi3
                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=OneWay}" Command="{Binding DataContext.ToggleTaskStatusCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,10,0"/>

                                    <CheckBox IsChecked="{Binding IsCompleted}" Command="{Binding DataContext.ToggleTaskStatusCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,10,0"/>
 main
                                    <StackPanel Width="500">
                                        <TextBlock Text="{Binding Title}" FontSize="15" TextDecorations="{Binding Status, Converter={StaticResource StatusToTextDecorationConverter}}"/>
                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource MutedBrush}"/>
                                        <TextBlock Text="{Binding DueDate, StringFormat='Échéance: {0:dd/MM/yyyy HH:mm}'}" Foreground="{DynamicResource MutedBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ComboBox ItemsSource="{Binding DataContext.PriorityValues, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  SelectedItem="{Binding Priority}" Width="90" Margin="0,0,8,0"/>
                                        <Button Content="💾" Command="{Binding DataContext.SaveTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Margin="0,0,8,0"/>
                                        <Button Content="🗑" Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" Padding="14">
            <StackPanel>
                <TextBlock Text="Détails" FontSize="20" FontWeight="Bold"/>
                <TextBox Text="{Binding SelectedTask.Title}" Margin="0,10,0,8"/>
                <TextBox Text="{Binding SelectedTask.Description}" Height="120" AcceptsReturn="True" TextWrapping="Wrap"/>
                <DatePicker SelectedDate="{Binding SelectedTask.DueDate}" Margin="0,8,0,8"/>
                <ComboBox SelectedItem="{Binding SelectedTask.Priority}" ItemsSource="{Binding PriorityValues}"/>
                <Button Content="Sauvegarder" Command="{Binding SaveTaskCommand}" CommandParameter="{Binding SelectedTask}" Margin="0,10,0,0"/>
                <TextBlock Margin="0,14,0,4" Text="Raccourcis:" FontWeight="Bold"/>
                <TextBlock Text="Ctrl+N : nouvelle tâche" Foreground="{DynamicResource MutedBrush}"/>
                <TextBlock Text="Ctrl+D : thème sombre/clair" Foreground="{DynamicResource MutedBrush}"/>
                <TextBlock Text="Suppr : supprimer tâche" Foreground="{DynamicResource MutedBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
